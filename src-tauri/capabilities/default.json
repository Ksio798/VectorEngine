{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for VectorEngine",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        {
          "path": "$DOCUMENT/VectorEngine"
        },
        {
          "path": "$DOCUMENT/VectorEngine/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        {
          "path": "$DOCUMENT/VectorEngine"
        },
        {
          "path": "$DOCUMENT/VectorEngine/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        {
          "path": "$DOCUMENT/VectorEngine/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        {
          "path": "$DOCUMENT/VectorEngine/**"
        }
      ]
    }
  ]
}